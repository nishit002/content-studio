# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── BrightData (optional but strongly recommended) ────────────────────────────
# Without this: the script uses direct HTTP (works for most .gov.in/.ac.in sites)
# With this: bypasses anti-bot on JS-heavy sites, gets fully rendered pages
#
# How to get your zone name:
#   1. Log into app.brightdata.com
#   2. Go to Proxies & Scraping Infrastructure → Web Unlocker
#   3. Create a new zone (or use existing) — copy the zone name shown there
#   4. Your API key is your Bearer token from Account Settings → API Token
#
BRIGHT_DATA_KEY=your-brightdata-bearer-token
BRIGHT_DATA_ZONE=web_unlocker1

# ── LM Studio ─────────────────────────────────────────────────────────────────
# Open LM Studio → Local Server tab → Start Server
# Load the model you want to use, then start the server
#
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=meta-llama-3.1-8b-instruct
