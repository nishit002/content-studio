# Content Studio — API Keys & Secrets
# Copy this to .env.local and fill in your values

# Gemini API Keys (comma-separated for rotation)
GEMINI_API_KEYS=your-key-1,your-key-2,your-key-3

# HuggingFace Writer Keys (comma-separated)
HF_API_KEYS=hf_your_key_1,hf_your_key_2

# You.com Search Keys (comma-separated, supports many keys for rotation)
YOU_API_KEYS=ydc-sk-your-key-1,ydc-sk-your-key-2

# Image Generation (HuggingFace key for FLUX.1-schnell)
IMAGE_API_KEY=hf_your_key

# WordPress
WP_SITE_URL=https://your-site.com
WP_USERNAME=your_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Supabase (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Ads API (optional - for LSI keywords)
GADS_DEVELOPER_TOKEN=
GADS_CLIENT_ID=
GADS_CLIENT_SECRET=
GADS_REFRESH_TOKEN=
GADS_LOGIN_CUSTOMER_ID=

# DataForSEO (optional - for keyword enrichment)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
